<Window x:Class="Min_BID.AddEditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Min_BID"
        mc:Ignorable="d"
        Title="AddEditUserWindow" Height="450" Width="800">
    <Grid Margin="0,-10,0,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="61"/>
            <RowDefinition Height="Auto" MinHeight="61"/>
            <RowDefinition Height="Auto" MinHeight="62.02"/>
            <RowDefinition Height="Auto" MinHeight="57.28"/>
            <RowDefinition Height="Auto" MinHeight="63"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="209"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="1" Text="Логин:" Margin="5,0,0,0" Height="22" Width="48"/>
        <TextBox x:Name="txtLogin" Grid.Row="1" Grid.Column="1" Margin="5,5,5,5" MaxLength="50"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Пароль:" Margin="5,0,0,0" Height="22" Width="58"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="2" Grid.Column="1" Margin="5,5,5,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Подтверждение пароля:" Margin="5,0,0,0" Height="21" Width="179"/>
        <PasswordBox x:Name="txtPasswordConfirm" Grid.Row="3" Grid.Column="1" Margin="5,5,5,5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Роль:" Margin="5,0,0,0" Height="21" Width="38"/>
        <ComboBox x:Name="cmbRole" Grid.Row="4" Grid.Column="1" Margin="5,5,5,5"
                  DisplayMemberPath="Name" SelectedValuePath="ID"/>

        <CheckBox x:Name="chkChangePassword" Grid.Row="5" Grid.ColumnSpan="2" 
                  Content="Изменить пароль" Margin="5,1,5,66" Visibility="Collapsed"/>
        <StackPanel Grid.Row="6" 
                Orientation="Horizontal"  Margin="85,10,294,10" Grid.Column="1">
            <Button x:Name="BtnSave" Content="Сохранить" 
                Click="btnSave_Click" Width="200"/>
        </StackPanel>
    </Grid>
</Window>
