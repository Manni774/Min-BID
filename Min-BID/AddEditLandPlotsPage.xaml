<Page x:Class="Min_BID.AddEditLandPlotsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Min_BID"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница редактирования земельных участков">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="16*"/>
            <RowDefinition Height="63*"/>
            <RowDefinition Height="50*"/>
            <RowDefinition Height="50*"/>
            <RowDefinition Height="63*"/>
            <RowDefinition Height="52*"/>
            <RowDefinition Height="66*"/>
            <RowDefinition Height="90*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="233*"/>
            <ColumnDefinition Width="567*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="1" Text="Участок" Height="22" Margin="17,0,0,0" Width="159" />
        <TextBlock Grid.Row="2" Text="Кадастровый номер" Height="22" Margin="17,0,0,0" Width="159" />
        <TextBlock Grid.Row="3" Text="Адрес" Height="20" Margin="17,0,0,0" Width="85"></TextBlock>
        <TextBlock Grid.Row="4" Text="Использование" Height="22" Width="215" Margin="17,0,0,0"/>
        <TextBlock Grid.Row="5" Text="Дата постановки на учет" Height="22" Width="215" Margin="17,0,0,0"/>
        <TextBlock Grid.Row="6" Text="Статус" Height="22" Margin="17,0,0,0" Width="100" ></TextBlock>
        <ComboBox x:Name="CmbRegion" 
            Grid.Row="1" Grid.Column="1" 
            Margin="33,5,34,5"
            DisplayMemberPath="Название_района"
            SelectedValuePath="ID"      
            SelectedValue="{Binding RegionID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
        </ComboBox>
        <TextBox Text="{Binding Кадастровый_номер}" MaxLength="500" 
             Grid.Row="2" Grid.Column="1"  Margin="33,3,34,5"/>
        <TextBox Text="{Binding Адрес}" MaxLength="500" 
             Grid.Row="3" Grid.Column="1" Margin="33,3,34,5"/>
        <ComboBox x:Name="CmbCategoryName" 
            Grid.Row="4" Grid.Column="1" 
            Margin="33,5,34,5"
            DisplayMemberPath="Наименование_участка"
            SelectedValuePath="ID"      
            SelectedValue="{Binding LandCategoriesID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
        </ComboBox>
        <DatePicker SelectedDate="{Binding Дата_постановки_на_учет}" 
                Grid.Row="5" Grid.Column="1" Margin="0,5,0,5" Width="500" HorizontalAlignment="Center" />
        <ComboBox x:Name="CmbStatus" 
                Grid.Row="6" Grid.Column="1" 
                Margin="33,5,34,5"
                DisplayMemberPath="Статус"
                SelectedValuePath="ID"
                SelectedValue="{Binding StatusID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
        </ComboBox>
        <StackPanel Grid.Row="7" 
                Orientation="Horizontal" 
                HorizontalAlignment="Left" Margin="73,10,0,10" Width="210" Grid.Column="1">
            <Button x:Name="BtnSave" Content="Сохранить" 
                Click="BtnSave_Click" Width="200" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>
