<Page x:Class="Min_BID.FourButtonsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Min_BID"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FourButtonsPage">

    <Grid>
        <StackPanel Margin="240,27,240,0">
                <Button x:Name="btnLeaseAgreements" Content="Договоры аренды" Click="btnLeaseAgreements_Click" Height="40" Margin="0,5"/>
                <Button x:Name="btnLandPlots" Content="Земельные участки" Click="btnLandPlots_Click" Height="40" Margin="0,5"/>
                <Button x:Name="btnUsers" Content="Пользователи" Click="btnUsers_Click" Height="40" Margin="0,5"/>
                <Button x:Name="btnAnalytics" Content="Аналитика" Click="btnAnalytics_Click" Height="40" Margin="0,5"/>
            </StackPanel>
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>
