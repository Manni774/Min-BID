<Page x:Class="Min_BID.LandPlotsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Min_BID"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Земельные участки" IsVisibleChanged="Page_IsVisibleChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="353*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Управление пользователями" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Margin="10"/>
        <DataGrid x:Name="dgLandPlots" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Кадастровый номер" Binding="{Binding Кадастровый_номер}" Width="200"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Адрес}" Width="300"/>
                <DataGridTextColumn Header="Использование" Binding="{Binding Разрешенное_использование}" Width="150"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusID}" Width="100"/>
                <DataGridTemplateColumn Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Редактировать" Name="BtnEdit" Click="BtnEdit_Click"></Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Name="BtnDelete" Grid.Row="1" Content="Удалить" Width="150" HorizontalAlignment="Left" Click="BtnDelete_Click"/>
            <Button Name="BtnAdd" Grid.Row="1" Content="Добавить" Width="150" HorizontalAlignment="Left" Click="BtnAdd_Click"/>
        </StackPanel>
    </Grid>
</Page>
