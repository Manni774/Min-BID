<Window x:Class="Min_BID.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Min_BID"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65*"/>
            <RowDefinition Height="353*"/>
            <RowDefinition Height="16*"/>
        </Grid.RowDefinitions>
        <Grid Background="#0b412d" Panel.ZIndex="-2"></Grid>
        <Grid Grid.Row="2" Background="#0b412d" Margin="0,2,0,0"/>
        <Grid Grid.Row="1" Background="#ecfef4" Margin="0,1,0,0"></Grid>
        <Image Source="/Resources/Логотип Минземимущества_w110_fitted.jpg" HorizontalAlignment="Left" Width="66"></Image>
        <Frame NavigationUIVisibility="Hidden" ContentRendered="MainFrame_ContentRendered" Grid.Row="1" Name="MainFrame" Margin="0,1,0,0"></Frame>
        <Button Content="Обратно" Name="Btnback" Width="150" HorizontalAlignment="Left" Margin="598,13,0,13" Click="Btnback_Click"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="btnLeaseAgreements" Content="Договоры аренды" Click="btnLeaseAgreements_Click" Width="175"/>
            <Button x:Name="btnLandPlots" Content="Земельные участки" Click="btnLandPlots_Click" Width="175"/>
            <Button x:Name="btnUsers" Content="Пользователи" Click="btnUsers_Click" Width="175"/>
            <Button x:Name="btnAnalytics" Content="Аналитика" Click="btnAnalytics_Click" Width="175"/>
        </StackPanel>
    </Grid>
</Window>
